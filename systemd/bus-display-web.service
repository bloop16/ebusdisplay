[Unit]
Description=Bus Display Web Interface
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/bus-display
Environment=PYTHONPATH=/home/pi/bus-display
ExecStart=/usr/bin/python3 -m flask --app src.web.app:create_app run --host=0.0.0.0 --port=5000
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
